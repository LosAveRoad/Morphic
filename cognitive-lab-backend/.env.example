# DeepSeek API Configuration
DEEPSEEK_API_KEY=your_deepseek_api_key_here  # Required: Your API key from DeepSeek platform
DEEPSEEK_BASE_URL=https://api.deepseek.com  # Optional: Custom API endpoint
DEEPSEEK_MODEL=deepseek-chat  # Optional: Model selection

# Server Configuration
PORT=3000  # Server port (default: 3000)
NODE_ENV=development  # Environment: development, production, test

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379  # Redis connection string
REDIS_ENABLED=false  # Set to 'true' to enable Redis caching

# Session Configuration
SESSION_TTL=3600  # Session time-to-live in seconds (default: 1 hour)

# Logging Configuration
LOG_LEVEL=debug  # Log level: debug, info, warn, error
